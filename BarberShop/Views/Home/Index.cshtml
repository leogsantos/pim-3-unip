<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Barbearia JLMGG</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/tabler-icons.min.css"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#080808;
  --surface:#0f0f0f;
  --surface2:#141414;
  --surface3:#1a1a1a;
  --surface4:#202020;
  --blue:#4fc3f7;
  --blue2:#0288d1;
  --blue3:#01579b;
  --blue-dim:rgba(79,195,247,0.08);
  --blue-dim2:rgba(79,195,247,0.14);
  --blue-border:rgba(79,195,247,0.22);
  --blue-border2:rgba(79,195,247,0.40);
  --text:#f0f0f0;
  --text2:#888;
  --text3:#3a3a3a;
  --red:#ef5350;
  --red-dim:rgba(239,83,80,0.08);
  --red-border:rgba(239,83,80,0.28);
  --r:14px;
  --r-sm:9px;
  --sidebar:260px;
}

html,body{height:100%;overflow:hidden;}
body{
  background:var(--bg);
  font-family:'DM Sans',sans-serif;
  color:var(--text);
  display:flex;
}

/* ══ SCROLLBAR ══ */
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:4px;}

/* ══ SIDEBAR ══ */
.sidebar{
  width:var(--sidebar);
  background:var(--surface);
  border-right:0.5px solid #1a1a1a;
  display:flex;flex-direction:column;
  flex-shrink:0;height:100vh;
  position:relative;z-index:10;
}
.sidebar-brand{
  padding:28px 22px 22px;
  border-bottom:0.5px solid #1a1a1a;
  display:flex;align-items:center;gap:13px;
}
.brand-logo{
  width:46px;height:46px;border-radius:50%;
  background:linear-gradient(135deg,#0277bd,#01579b);
  display:flex;align-items:center;justify-content:center;
  border:1.5px solid var(--blue-border);
  box-shadow:0 0 20px rgba(2,136,209,0.2);
  flex-shrink:0;
}
.brand-logo span{font-family:'Bebas Neue',sans-serif;font-size:16px;color:#fff;letter-spacing:2px;}
.brand-info{overflow:hidden;}
.brand-name{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:2px;color:var(--text);white-space:nowrap;}
.brand-sub{font-size:10px;color:var(--text2);margin-top:1px;letter-spacing:0.5px;}

.sidebar-nav{flex:1;padding:16px 12px;overflow-y:auto;}
.nav-section-label{
  font-size:9px;color:var(--text3);letter-spacing:2.5px;
  text-transform:uppercase;font-weight:500;
  padding:0 10px;margin:16px 0 8px;
}
.nav-section-label:first-child{margin-top:4px;}
.nav-item{
  display:flex;align-items:center;gap:11px;
  padding:10px 12px;border-radius:var(--r-sm);
  cursor:pointer;color:var(--text2);font-size:13px;font-weight:400;
  transition:all .18s;position:relative;
  border:0.5px solid transparent;
  margin-bottom:2px;
}
.nav-item i{font-size:18px;flex-shrink:0;}
.nav-item:hover{background:var(--surface2);color:var(--text);}
.nav-item.active{
  background:var(--blue-dim2);
  border-color:var(--blue-border);
  color:var(--blue);
}
.nav-item.active::before{
  content:'';position:absolute;left:0;top:20%;bottom:20%;
  width:2px;border-radius:2px;background:var(--blue);
}

.sidebar-footer{
  padding:16px 12px;
  border-top:0.5px solid #1a1a1a;
}
.user-card{
  display:flex;align-items:center;gap:10px;
  padding:10px 12px;border-radius:var(--r-sm);
  background:var(--surface2);border:0.5px solid #1a1a1a;
  cursor:pointer;transition:border-color .2s;
}
.user-card:hover{border-color:var(--blue-border);}
.user-avatar{
  width:34px;height:34px;border-radius:50%;
  background:linear-gradient(135deg,#0277bd,#01579b);
  display:flex;align-items:center;justify-content:center;
  font-family:'Bebas Neue',sans-serif;font-size:12px;color:#fff;
  flex-shrink:0;
}
.user-info{flex:1;overflow:hidden;}
.user-name{font-size:12px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.user-email{font-size:10px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.user-logout{color:var(--text3);font-size:16px;cursor:pointer;transition:color .2s;flex-shrink:0;}
.user-logout:hover{color:var(--red);}

/* ══ MAIN ══ */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;position:relative;}

.topbar{
  background:var(--surface);border-bottom:0.5px solid #1a1a1a;
  padding:0 32px;height:60px;
  display:flex;align-items:center;justify-content:space-between;
  flex-shrink:0;
}
.topbar-left{display:flex;align-items:center;gap:10px;}
.breadcrumb{font-size:12px;color:var(--text2);}
.breadcrumb .sep{margin:0 6px;color:var(--text3);}
.breadcrumb .current{color:var(--text);font-weight:500;}
.topbar-right{display:flex;align-items:center;gap:12px;}
.topbar-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--blue-dim);border:0.5px solid var(--blue-border);
  color:var(--blue);font-size:11px;padding:5px 12px;
  border-radius:20px;
}
.topbar-badge i{font-size:13px;}

.content{flex:1;overflow-y:auto;padding:32px;}

/* ══ SCREENS ══ */
.screen{display:none;}
.screen.active{display:block;}


.password-strength{margin-top:8px;}
.strength-bar{height:3px;border-radius:2px;background:#1e1e1e;overflow:hidden;}
.strength-fill{height:100%;border-radius:2px;transition:width .3s,background .3s;}
.strength-label{font-size:10px;color:var(--text3);margin-top:4px;}

/* ══ HOME SCREEN ══ */
.page-header{margin-bottom:28px;}
.page-title{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:3px;color:var(--text);}
.page-sub{font-size:13px;color:var(--text2);margin-top:4px;}

.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:28px;}
.stat-card{
  background:var(--surface);border:0.5px solid #1a1a1a;
  border-radius:var(--r);padding:18px 20px;
  transition:border-color .2s;
}
.stat-card:hover{border-color:var(--blue-border);}
.stat-icon{
  width:36px;height:36px;border-radius:var(--r-sm);
  background:var(--blue-dim);border:0.5px solid var(--blue-border);
  display:flex;align-items:center;justify-content:center;
  color:var(--blue);font-size:17px;margin-bottom:12px;
}
.stat-val{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:1px;color:var(--text);}
.stat-lbl{font-size:11px;color:var(--text2);margin-top:2px;}

.section-label{
  font-size:10px;color:var(--text3);letter-spacing:2.5px;
  text-transform:uppercase;font-weight:500;margin-bottom:16px;
}

/* ══ CAT GRID ══ */
.cat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:28px;}
.cat-card{
  background:var(--surface);border:0.5px solid #1a1a1a;
  border-radius:var(--r);padding:20px 18px;
  cursor:pointer;transition:border-color .2s,transform .15s,background .2s;
  position:relative;overflow:hidden;
}
.cat-card::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(79,195,247,0.04),transparent);
  opacity:0;transition:opacity .2s;
}
.cat-card:hover{border-color:var(--blue-border);transform:translateY(-2px);}
.cat-card:hover::after{opacity:1;}
.cat-card:active{transform:scale(0.99);}
.cat-icon{
  width:42px;height:42px;border-radius:var(--r-sm);
  background:var(--blue-dim);border:0.5px solid var(--blue-border);
  display:flex;align-items:center;justify-content:center;
  color:var(--blue);font-size:20px;margin-bottom:12px;
}
.cat-card h4{font-size:15px;font-weight:500;color:var(--text);}
.cat-card p{font-size:11px;color:var(--text3);margin-top:3px;}
.cat-arrow{position:absolute;right:16px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:16px;}

/* ══ SERVICES SCREEN ══ */
.back-row{display:flex;align-items:center;gap:10px;margin-bottom:24px;cursor:pointer;color:var(--text2);transition:color .2s;}
.back-row:hover{color:var(--blue);}
.back-row i{font-size:18px;}
.back-row span{font-size:13px;font-weight:500;}

.services-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;}
.service-item{
  background:var(--surface);border:0.5px solid #1a1a1a;
  border-radius:var(--r);padding:18px 20px;
  cursor:pointer;display:flex;align-items:center;justify-content:space-between;
  transition:border-color .2s,transform .15s;
}
.service-item:hover{border-color:var(--blue-border);transform:translateX(2px);}
.service-item:active{transform:scale(0.99);}
.srv-name{font-size:15px;font-weight:500;color:var(--text);}
.srv-desc{font-size:12px;color:var(--text2);margin-top:3px;}
.srv-price{
  font-family:'Bebas Neue',sans-serif;
  font-size:20px;letter-spacing:1px;color:var(--blue);
  white-space:nowrap;margin-left:16px;
}

/* ══ CALENDAR SCREEN ══ */
.calendar-layout{display:grid;grid-template-columns:340px 1fr;gap:20px;align-items:start;}

.cal-panel{background:var(--surface);border:0.5px solid #1a1a1a;border-radius:var(--r);padding:20px;}
.month-tabs{display:flex;gap:8px;margin-bottom:18px;}
.month-tab{
  flex:1;padding:9px;border-radius:var(--r-sm);
  border:0.5px solid #1a1a1a;background:var(--surface2);
  color:var(--text2);font-size:12px;font-weight:500;
  cursor:pointer;text-align:center;transition:all .2s;
}
.month-tab.active{background:var(--blue-dim);border-color:var(--blue-border);color:var(--blue);}
.cal-month-name{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;color:var(--text);margin-bottom:14px;}
.weekdays{display:grid;grid-template-columns:repeat(7,1fr);text-align:center;margin-bottom:6px;}
.weekdays span{font-size:10px;color:var(--text3);padding:4px 0;letter-spacing:0.5px;}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;}
.cal-day{
  aspect-ratio:1;display:flex;align-items:center;justify-content:center;
  font-size:13px;color:var(--text2);border-radius:var(--r-sm);
  cursor:pointer;transition:all .15s;
}
.cal-day.empty,.cal-day.past{color:var(--text3);cursor:not-allowed;}
.cal-day:not(.empty):not(.past):hover{background:var(--blue-dim);color:var(--blue);}
.cal-day.selected{background:var(--blue2);color:#fff;font-weight:500;}
.cal-day.today{border:0.5px solid var(--blue-border);color:var(--blue);}
.cal-day.today.selected{border-color:var(--blue2);}

.barbers-panel{background:var(--surface);border:0.5px solid #1a1a1a;border-radius:var(--r);padding:20px;}
.barber-card{
  border:0.5px solid #1a1a1a;
  border-radius:var(--r-sm);padding:16px;margin-bottom:10px;
  transition:border-color .2s;
}
.barber-card:hover{border-color:var(--blue-border);}
.barber-header{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
.barber-avatar{
  width:42px;height:42px;border-radius:50%;
  background:linear-gradient(135deg,#0277bd,#01579b);
  display:flex;align-items:center;justify-content:center;
  font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:1px;color:#fff;
  border:1px solid var(--blue-border);flex-shrink:0;
}
.barber-name{font-size:14px;font-weight:500;color:var(--text);}
.barber-slots-count{font-size:11px;color:var(--text3);margin-top:2px;}
.time-slots{display:flex;flex-wrap:wrap;gap:7px;}
.time-slot{
  background:var(--bg);border:0.5px solid #252525;
  color:var(--text2);font-size:12px;padding:6px 13px;
  border-radius:20px;cursor:pointer;transition:all .2s;
}
.time-slot:hover{border-color:var(--blue-border);color:var(--blue);background:var(--blue-dim);}
.time-slot.selected{background:var(--blue2);border-color:var(--blue2);color:#fff;}

.cal-placeholder{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:60px 20px;color:var(--text3);text-align:center;
}
.cal-placeholder i{font-size:48px;opacity:.3;margin-bottom:14px;}
.cal-placeholder p{font-size:13px;line-height:1.7;}

/* ══ CONFIRM SCREEN ══ */
.confirm-layout{display:grid;grid-template-columns:1fr 380px;gap:20px;align-items:start;}
.confirm-card{
  background:var(--surface);border:0.5px solid #1a1a1a;
  border-radius:var(--r);padding:22px;margin-bottom:16px;
}
.card-label{font-size:10px;color:var(--text3);letter-spacing:2px;text-transform:uppercase;margin-bottom:16px;}
.confirm-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:11px 0;border-bottom:0.5px solid #141414;
}
.confirm-row:last-child{border-bottom:none;}
.confirm-row .lbl{font-size:13px;color:var(--text2);display:flex;align-items:center;gap:7px;}
.confirm-row .lbl i{font-size:15px;}
.confirm-row .val{font-size:14px;color:var(--text);font-weight:500;}
.confirm-row .val.price{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:1px;color:var(--blue);}

/* ══ APPOINTMENTS ══ */
.appts-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:14px;}
.appt-card{
  background:var(--surface);border:0.5px solid #1a1a1a;
  border-radius:var(--r);padding:20px;
  animation:slideIn .3s ease;
  transition:border-color .2s;
}
.appt-card:hover{border-color:var(--blue-border);}
@@keyframes slideIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
.appt-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;}
.appt-service{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:1px;color:var(--text);}
.appt-badge{
  font-size:10px;padding:4px 10px;border-radius:20px;
  background:rgba(79,195,247,0.10);border:0.5px solid var(--blue-border);color:var(--blue);
  white-space:nowrap;flex-shrink:0;margin-left:8px;margin-top:2px;
}
.appt-row{display:flex;align-items:center;gap:8px;margin-bottom:7px;}
.appt-row:last-child{margin-bottom:0;}
.appt-row i{font-size:14px;color:var(--text3);}
.appt-row span{font-size:12px;color:var(--text2);}
.appt-row .hl{color:var(--text);}
.appt-row .hl-blue{color:var(--blue);}
.appt-actions{display:flex;gap:8px;margin-top:16px;padding-top:14px;border-top:0.5px solid #141414;}
.appt-btn{
  flex:1;display:flex;align-items:center;justify-content:center;gap:6px;
  padding:9px 0;border-radius:var(--r-sm);
  font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:1px;
  cursor:pointer;border:none;transition:all .2s;
}
.appt-btn-edit{background:var(--blue-dim);border:0.5px solid var(--blue-border);color:var(--blue);}
.appt-btn-edit:hover{background:var(--blue-dim2);}
.appt-btn-cancel{background:var(--red-dim);border:0.5px solid var(--red-border);color:var(--red);}
.appt-btn-cancel:hover{background:rgba(239,83,80,0.14);}
.appt-btn i{font-size:14px;}

.empty-state{
  grid-column:1/-1;text-align:center;
  padding:80px 20px;color:var(--text3);
}
.empty-state i{font-size:52px;margin-bottom:16px;display:block;opacity:.3;}
.empty-state p{font-size:14px;line-height:1.7;}

/* ══ MODAL ══ */
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.65);
  display:flex;align-items:center;justify-content:center;
  z-index:200;animation:fadeIn .2s ease;
}
@@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
.modal-box{
  background:var(--surface);border:0.5px solid #252525;
  border-radius:16px;padding:28px 28px 24px;
  width:100%;max-width:400px;
  box-shadow:0 0 60px rgba(0,0,0,0.6);
  animation:scaleIn .2s ease;
}
@@keyframes scaleIn{from{opacity:0;transform:scale(0.96);}to{opacity:1;transform:scale(1);}}
.modal-title{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;color:var(--text);margin-bottom:8px;}
.modal-sub{font-size:13px;color:var(--text2);margin-bottom:22px;line-height:1.6;}
.modal-service{color:var(--blue);font-weight:500;}
.modal-actions{display:flex;flex-direction:column;gap:10px;}

/* ══ SUCCESS OVERLAY ══ */
.success-overlay{
  position:fixed;inset:0;background:rgba(8,8,8,0.92);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  z-index:300;animation:fadeIn .3s ease;text-align:center;padding:32px;
}
.success-icon{
  width:90px;height:90px;border-radius:50%;
  background:rgba(79,195,247,0.10);border:1.5px solid var(--blue-border);
  display:flex;align-items:center;justify-content:center;
  color:var(--blue);font-size:40px;margin-bottom:22px;
  box-shadow:0 0 40px rgba(79,195,247,0.15);
}
.success-title{font-family:'Bebas Neue',sans-serif;font-size:36px;letter-spacing:3px;color:var(--text);margin-bottom:10px;}
.success-sub{font-size:15px;color:var(--text2);line-height:1.7;margin-bottom:32px;max-width:360px;}
.btn-ok{
  background:var(--blue2);color:#fff;border:none;
  border-radius:var(--r-sm);padding:14px 40px;
  font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:2px;
  cursor:pointer;transition:background .2s,box-shadow .2s;
}
.btn-ok:hover{background:#0277bd;box-shadow:0 4px 20px rgba(2,136,209,0.3);}

/* ══ CONFIRM SUMMARY CARD ══ */
.summary-sticky{position:sticky;top:0;}

</style>
</head>
<body>

<!-- ══════════════════════════ APP LAYOUT ══════════════════════════ -->
<div id="app-layout" style="display:flex;width:100%;height:100%;overflow:hidden;flex-direction:row;">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="brand-logo"><span>JL</span></div>
      <div class="brand-info">
        <div class="brand-name">JLMGG</div>
        <div class="brand-sub">Qualidade &amp; Estilo</div>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section-label">Menu</div>
      <div class="nav-item active" id="nav-home" onclick="gotoApp('a-home')">
        <i class="ti ti-home"></i> Início
      </div>
      <div class="nav-item" id="nav-appts" onclick="gotoApp('a-appts');updateAppts()">
        <i class="ti ti-calendar"></i> Agendamentos
      </div>
      <div class="nav-section-label">Serviços</div>
      <div class="nav-item" onclick="showServices('corte');gotoApp('a-services')">
        <i class="ti ti-cut"></i> Corte
      </div>
      <div class="nav-item" onclick="showServices('combos');gotoApp('a-services')">
        <i class="ti ti-package"></i> Combos
      </div>
      <div class="nav-item" onclick="showServices('servicos');gotoApp('a-services')">
        <i class="ti ti-brush"></i> Serviços
      </div>
      <div class="nav-item" onclick="showServices('quimicas');gotoApp('a-services')">
        <i class="ti ti-droplet"></i> Químicas
      </div>
    </nav>
    <div class="sidebar-footer">
      <div class="user-card">
        <div class="user-avatar" id="user-avatar-initials">JP</div>
        <div class="user-info">
          <div class="user-name" id="sidebar-user-name">João Pedro</div>
          <div class="user-email" id="sidebar-user-email">joao@email.com</div>
        </div>
        <i class="ti ti-logout user-logout" title="Sair" onclick="doLogout()"></i>
      </div>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="main">
    <div class="topbar">
      <div class="topbar-left">
        <div class="breadcrumb" id="breadcrumb">
          <span>Barbearia JLMGG</span>
          <span class="sep">/</span>
          <span class="current" id="bc-current">Início</span>
        </div>
      </div>
      <div class="topbar-right">
        <div class="topbar-badge"><i class="ti ti-clock"></i> Seg–Sáb &nbsp;·&nbsp; 9h às 20h</div>
      </div>
    </div>

    <div class="content">

      <!-- ── HOME ── -->
      <div class="screen active" id="a-home">
        <div class="page-header">
          <div class="page-title">Bem-vindo de volta!</div>
          <div class="page-sub">Escolha um serviço e agende seu horário</div>
        </div>
        <div class="stats-row">
          <div class="stat-card">
            <div class="stat-icon"><i class="ti ti-calendar-check"></i></div>
            <div class="stat-val" id="stat-total">0</div>
            <div class="stat-lbl">Agendamentos</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon"><i class="ti ti-users"></i></div>
            <div class="stat-val">5</div>
            <div class="stat-lbl">Barbeiros</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon"><i class="ti ti-scissors"></i></div>
            <div class="stat-val">14</div>
            <div class="stat-lbl">Serviços</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon"><i class="ti ti-star"></i></div>
            <div class="stat-val">4.9</div>
            <div class="stat-lbl">Avaliação</div>
          </div>
        </div>
        <div class="section-label">Escolha o serviço</div>
        <div class="cat-grid">
          <div class="cat-card" onclick="showServices('corte');gotoApp('a-services')">
            <div class="cat-icon"><i class="ti ti-cut"></i></div>
            <h4>Corte</h4><p>2 opções</p>
            <i class="ti ti-chevron-right cat-arrow"></i>
          </div>
          <div class="cat-card" onclick="showServices('infantil');gotoApp('a-services')">
            <div class="cat-icon"><i class="ti ti-star"></i></div>
            <h4>Corte Infantil</h4><p>2 opções</p>
            <i class="ti ti-chevron-right cat-arrow"></i>
          </div>
          <div class="cat-card" onclick="showServices('combos');gotoApp('a-services')">
            <div class="cat-icon"><i class="ti ti-package"></i></div>
            <h4>Combos</h4><p>2 opções</p>
            <i class="ti ti-chevron-right cat-arrow"></i>
          </div>
          <div class="cat-card" onclick="showServices('servicos');gotoApp('a-services')">
            <div class="cat-icon"><i class="ti ti-brush"></i></div>
            <h4>Serviços</h4><p>3 opções</p>
            <i class="ti ti-chevron-right cat-arrow"></i>
          </div>
          <div class="cat-card" onclick="showServices('quimicas');gotoApp('a-services')">
            <div class="cat-icon"><i class="ti ti-droplet"></i></div>
            <h4>Químicas</h4><p>3 opções</p>
            <i class="ti ti-chevron-right cat-arrow"></i>
          </div>
        </div>
      </div>

      <!-- ── SERVICES ── -->
      <div class="screen" id="a-services">
        <div class="back-row" onclick="gotoApp('a-home')">
          <i class="ti ti-arrow-left"></i>
          <span>Voltar</span>
        </div>
        <div class="page-header" style="margin-bottom:20px">
          <div class="page-title" id="srv-title-desk">Corte</div>
          <div class="page-sub">Selecione um serviço para continuar</div>
        </div>
        <div class="services-grid" id="srv-list-desk"></div>
      </div>

      <!-- ── CALENDAR ── -->
      <div class="screen" id="a-calendar">
        <div class="back-row" onclick="gotoApp('a-services')">
          <i class="ti ti-arrow-left"></i>
          <span>Voltar para serviços</span>
        </div>
        <div class="page-header" style="margin-bottom:20px">
          <div class="page-title">Escolha a Data</div>
          <div class="page-sub" id="cal-srv-label-desk">—</div>
        </div>
        <div class="calendar-layout">
          <div class="cal-panel">
            <div id="cal-wrap-desk"></div>
          </div>
          <div class="barbers-panel" id="barbers-wrap-desk">
            <div class="cal-placeholder">
              <i class="ti ti-calendar-search"></i>
              <p>Selecione uma data no calendário<br/>para ver os barbeiros disponíveis.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- ── CONFIRM ── -->
      <div class="screen" id="a-confirm">
        <div class="back-row" onclick="gotoApp('a-calendar')">
          <i class="ti ti-arrow-left"></i>
          <span>Voltar ao calendário</span>
        </div>
        <div class="page-header" style="margin-bottom:20px">
          <div class="page-title">Confirmar Agendamento</div>
          <div class="page-sub">Revise os detalhes e preencha seus dados</div>
        </div>
        <div class="confirm-layout">
          <div>
            <div class="confirm-card">
              <div class="card-label">Seus dados</div>
              <div class="form-row">
                <div class="form-group">
                  <label>NOME COMPLETO</label>
                  <div class="input-icon-wrap">
                    <i class="ti ti-user inp-icon"></i>
                    <input type="text" id="inp-name" placeholder="Ex: João da Silva"/>
                  </div>
                </div>
                <div class="form-group">
                  <label>TELEFONE / WHATSAPP</label>
                  <div class="input-icon-wrap">
                    <i class="ti ti-phone inp-icon"></i>
                    <input type="tel" id="inp-phone" placeholder="(13) 99999-9999"/>
                  </div>
                </div>
              </div>
              <button class="btn-confirm" onclick="finalizeBooking()">
                <i class="ti ti-check"></i> CONFIRMAR AGENDAMENTO
              </button>
            </div>
          </div>
          <div class="summary-sticky">
            <div class="confirm-card">
              <div class="card-label">Resumo do agendamento</div>
              <div class="confirm-row">
                <span class="lbl"><i class="ti ti-cut"></i>Serviço</span>
                <span class="val" id="cf-srv">—</span>
              </div>
              <div class="confirm-row">
                <span class="lbl"><i class="ti ti-user"></i>Barbeiro</span>
                <span class="val" id="cf-barber">—</span>
              </div>
              <div class="confirm-row">
                <span class="lbl"><i class="ti ti-calendar"></i>Data</span>
                <span class="val" id="cf-date">—</span>
              </div>
              <div class="confirm-row">
                <span class="lbl"><i class="ti ti-clock"></i>Horário</span>
                <span class="val" id="cf-time">—</span>
              </div>
              <div class="confirm-row" style="border-bottom:none">
                <span class="lbl"><i class="ti ti-tag"></i>Valor</span>
                <span class="val price" id="cf-price">—</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── APPOINTMENTS ── -->
      <div class="screen" id="a-appts">
        <div class="page-header">
          <div class="page-title">Agendamentos</div>
          <div class="page-sub" id="appts-count-desk">Nenhum agendamento</div>
        </div>
        <div class="appts-grid" id="appts-list-desk">
          <div class="empty-state">
            <i class="ti ti-calendar-off"></i>
            <p>Nenhum agendamento registrado.<br/>Faça sua reserva na aba Início.</p>
          </div>
        </div>
      </div>

    </div><!-- /content -->
  </main>
</div><!-- /app-layout -->

<script>
// ══ DATA ══
const SERVICES={
  corte:[
    {name:'Corte Rápido',desc:'Corte tradicional masculino',price:'A consultar'},
    {name:'Corte com Lavagem',desc:'Corte + lavagem completa',price:'A consultar'}
  ],
  infantil:[
    {name:'Corte Rápido Infantil',desc:'Para crianças até 12 anos',price:'A consultar'},
    {name:'Corte com Risquinho',desc:'Corte especial com detalhes',price:'A consultar'}
  ],
  combos:[
    {name:'Corte + Barba',desc:'Combo completo',price:'R$ 70'},
    {name:'Corte + Sobrancelha',desc:'Combo masculino',price:'R$ 55'}
  ],
  servicos:[
    {name:'Barba',desc:'Aparar e modelar a barba',price:'R$ 20'},
    {name:'Sobrancelha',desc:'Design de sobrancelha',price:'R$ 15'},
    {name:'Pezinho',desc:'Acabamento no pescoço',price:'R$ 15'}
  ],
  quimicas:[
    {name:'Luzes',desc:'Mechas e luzes',price:'R$ 60'},
    {name:'Botox Capilar',desc:'Tratamento intensivo',price:'R$ 100'},
    {name:'Platinado',desc:'Descoloração completa',price:'R$ 120'}
  ]
};
const CAT_NAMES={corte:'Corte',infantil:'Corte Infantil',combos:'Combos',servicos:'Serviços',quimicas:'Químicas'};
const BARBERS=[
  {name:'João Pedro',initials:'JP'},
  {name:'Leonardo',initials:'LE'},
  {name:'Guilherme',initials:'GU'},
  {name:'Gabriel',initials:'GA'},
  {name:'Marcos',initials:'MA'}
];
const ALL_TIMES=['09:00','09:30','10:00','10:30','11:00','11:30','13:00','13:30','14:00','14:30','15:00','16:00','16:30','17:00','18:00','18:30','19:00'];
const MONTH_NAMES=['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

let state={service:null,date:null,barber:null,time:null,editIdx:null};
let appointments=[];
let calState={month:0,year:0,selectedDay:null,selectedBarber:null,selectedTime:null,viewMonth:0};
let loggedUser={name:'Administrador',email:'admin@barbearia.com',phone:''};

// 25502550 INIT (sem login) 25502550
window.addEventListener('DOMContentLoaded',function(){
  updateStats();
  gotoApp('a-home');
  document.getElementById('sidebar-user-name').textContent=loggedUser.name;
  document.getElementById('sidebar-user-email').textContent=loggedUser.email;
  document.getElementById('user-avatar-initials').textContent='AD';
});

// ══ APP NAVIGATION ══
const BC_LABELS={'a-home':'Início','a-services':'Serviços','a-calendar':'Agendar','a-confirm':'Confirmar','a-appts':'Agendamentos'};
function gotoApp(id){
  document.querySelectorAll('#app-layout .screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  // breadcrumb
  document.getElementById('bc-current').textContent=BC_LABELS[id]||id;
  // sidebar nav
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  if(id==='a-home'||id==='a-services'||id==='a-calendar'||id==='a-confirm')
    document.getElementById('nav-home').classList.add('active');
  if(id==='a-appts')document.getElementById('nav-appts').classList.add('active');
}

// ══ SERVICES ══
function showServices(catKey){
  document.getElementById('srv-title-desk').textContent=CAT_NAMES[catKey];
  const list=document.getElementById('srv-list-desk');
  list.innerHTML='';
  SERVICES[catKey].forEach(srv=>{
    const el=document.createElement('div');
    el.className='service-item';
    el.innerHTML=`<div><div class="srv-name">${srv.name}</div><div class="srv-desc">${srv.desc}</div></div><div class="srv-price">${srv.price}</div>`;
    el.onclick=()=>selectService(srv);
    list.appendChild(el);
  });
}

function selectService(srv){
  state.service=srv;
  document.getElementById('cal-srv-label-desk').textContent=srv.name;
  const now=new Date();
  calState.year=now.getFullYear();calState.month=now.getMonth();calState.viewMonth=now.getMonth();
  calState.selectedDay=null;calState.selectedBarber=null;calState.selectedTime=null;
  buildCalendar();
  gotoApp('a-calendar');
}

// ══ CALENDAR ══
function buildCalendar(){
  const now=new Date();
  const curMonth=now.getMonth(),curYear=now.getFullYear();
  const nextMonth=(curMonth+1)%12,nextYear=curMonth===11?curYear+1:curYear;
  const vm=calState.viewMonth;
  const vy=vm<curMonth?nextYear:curYear;

  let html=`<div class="month-tabs">
    <div class="month-tab${vm===curMonth?' active':''}" onclick="switchMonth(${curMonth},${curYear})">${MONTH_NAMES[curMonth]}</div>
    <div class="month-tab${vm===nextMonth?' active':''}" onclick="switchMonth(${nextMonth},${nextYear})">${MONTH_NAMES[nextMonth]}</div>
  </div>`;
  const firstDay=new Date(vy,vm,1).getDay();
  const daysInMonth=new Date(vy,vm+1,0).getDate();
  const todayD=now.getDate(),todayM=now.getMonth(),todayY=now.getFullYear();
  html+=`<div class="cal-month-name">${MONTH_NAMES[vm]} ${vy}</div>`;
  html+=`<div class="weekdays"><span>D</span><span>S</span><span>T</span><span>Q</span><span>Q</span><span>S</span><span>S</span></div>`;
  html+=`<div class="cal-grid">`;
  for(let i=0;i<firstDay;i++) html+=`<div class="cal-day empty"></div>`;
  for(let d=1;d<=daysInMonth;d++){
    const isToday=(d===todayD&&vm===todayM&&vy===todayY);
    const isPast=(vy<todayY)||(vy===todayY&&vm<todayM)||(vy===todayY&&vm===todayM&&d<todayD);
    const isSel=(d===calState.selectedDay&&vm===calState.viewMonth);
    const cls=['cal-day',isToday?'today':'',isPast?'past':'',isSel?'selected':''].filter(Boolean).join(' ');
    const click=isPast?'':`onclick="selectDay(${d},${vm},${vy})"`;
    html+=`<div class="${cls}" ${click}>${d}</div>`;
  }
  html+=`</div>`;
  document.getElementById('cal-wrap-desk').innerHTML=html;
  buildBarbers();
}

function buildBarbers(){
  const wrap=document.getElementById('barbers-wrap-desk');
  if(!calState.selectedDay){
    wrap.innerHTML=`<div class="cal-placeholder"><i class="ti ti-calendar-search"></i><p>Selecione uma data no calendário<br/>para ver os barbeiros disponíveis.</p></div>`;
    return;
  }
  const vm=calState.viewMonth;
  const vy=vm<new Date().getMonth()?(new Date().getFullYear()+1):new Date().getFullYear();
  const dd=String(calState.selectedDay).padStart(2,'0');
  const mm=String(vm+1).padStart(2,'0');
  const dateStr=`${dd}/${mm}/${vy}`;
  let html=`<div class="section-label" style="margin-bottom:16px">Barbeiros disponíveis — ${dateStr}</div>`;
  BARBERS.forEach((b,bi)=>{
    const slots=ALL_TIMES.filter((_,i)=>(i+bi)%3!==0);
    html+=`<div class="barber-card">
      <div class="barber-header">
        <div class="barber-avatar">${b.initials}</div>
        <div><div class="barber-name">${b.name}</div><div class="barber-slots-count">${slots.length} horários disponíveis</div></div>
      </div>
      <div class="time-slots">`;
    slots.forEach(t=>{
      const isSel=(calState.selectedBarber===b.name&&calState.selectedTime===t);
      html+=`<div class="time-slot${isSel?' selected':''}" onclick="selectSlot('${b.name}','${t}','${dateStr}')">${t}</div>`;
    });
    html+=`</div></div>`;
  });
  wrap.innerHTML=html;
}

function switchMonth(m,y){
  calState.viewMonth=m;calState.selectedDay=null;calState.selectedBarber=null;calState.selectedTime=null;
  buildCalendar();
}
function selectDay(d,m,y){
  calState.selectedDay=d;calState.viewMonth=m;calState.selectedBarber=null;calState.selectedTime=null;
  buildCalendar();
}
function selectSlot(barberName,time,dateStr){
  calState.selectedBarber=barberName;calState.selectedTime=time;
  buildBarbers();
  state.date=dateStr;state.barber=barberName;state.time=time;
  document.getElementById('cf-srv').textContent=state.service.name;
  document.getElementById('cf-barber').textContent=barberName;
  document.getElementById('cf-date').textContent=dateStr;
  document.getElementById('cf-time').textContent=time;
  document.getElementById('cf-price').textContent=state.service.price;
  gotoApp('a-confirm');
}

// ══ CONFIRM ══
function finalizeBooking(){
  const name=document.getElementById('inp-name').value.trim();
  const phone=document.getElementById('inp-phone').value.trim();
  if(!name||!phone){alert('Preencha seu nome e telefone para continuar.');return;}
  const newAppt={service:state.service.name,barber:state.barber,date:state.date,time:state.time,price:state.service.price,name,phone};
  if(state.editIdx!=null){appointments[state.editIdx]=newAppt;state.editIdx=null;}
  else appointments.push(newAppt);
  document.getElementById('inp-name').value='';
  document.getElementById('inp-phone').value='';
  calState.selectedDay=null;calState.selectedBarber=null;calState.selectedTime=null;
  updateStats();
  showSuccess(name);
}

function showSuccess(name){
  const overlay=document.createElement('div');
  overlay.className='success-overlay';
  overlay.innerHTML=`
    <div class="success-icon"><i class="ti ti-check"></i></div>
    <div class="success-title">Agendado!</div>
    <div class="success-sub">Olá, <strong>${name}</strong>!<br/>Seu horário foi confirmado com sucesso.<br/>Até lá!</div>
    <button class="btn-ok" onclick="this.closest('.success-overlay').remove();updateAppts();gotoApp('a-appts')">VER AGENDAMENTOS</button>`;
  document.body.appendChild(overlay);
}

// ══ APPOINTMENTS ══
function updateAppts(){
  const list=document.getElementById('appts-list-desk');
  const count=document.getElementById('appts-count-desk');
  if(appointments.length===0){
    list.innerHTML=`<div class="empty-state"><i class="ti ti-calendar-off"></i><p>Nenhum agendamento registrado.<br/>Faça sua reserva na aba Início.</p></div>`;
    count.textContent='Nenhum agendamento';
    return;
  }
  count.textContent=`${appointments.length} agendamento${appointments.length>1?'s':''}`;
  list.innerHTML=appointments.map((a,idx)=>`
    <div class="appt-card">
      <div class="appt-top">
        <span class="appt-service">${a.service}</span>
        <span class="appt-badge">Confirmado</span>
      </div>
      <div class="appt-row"><i class="ti ti-user"></i><span>Barbeiro: <span class="hl">${a.barber}</span></span></div>
      <div class="appt-row"><i class="ti ti-calendar"></i><span>${a.date} às <span class="hl">${a.time}</span></span></div>
      <div class="appt-row"><i class="ti ti-tag"></i><span>Valor: <span class="hl-blue">${a.price}</span></span></div>
      <div class="appt-row"><i class="ti ti-user-circle"></i><span class="hl">${a.name}</span><span>&nbsp;·&nbsp;${a.phone}</span></div>
      <div class="appt-actions">
        <button class="appt-btn appt-btn-edit" onclick="editAppt(${idx})"><i class="ti ti-pencil"></i> ALTERAR</button>
        <button class="appt-btn appt-btn-cancel" onclick="confirmCancel(${idx})"><i class="ti ti-trash"></i> CANCELAR</button>
      </div>
    </div>`).join('');
}

function updateStats(){
  document.getElementById('stat-total').textContent=appointments.length;
}

// ══ CANCEL ══
function confirmCancel(idx){
  const a=appointments[idx];
  const modal=document.createElement('div');
  modal.className='modal-overlay';
  modal.id='cancel-modal';
  modal.innerHTML=`
    <div class="modal-box">
      <div class="modal-title">Cancelar agendamento</div>
      <div class="modal-sub">Deseja cancelar <span class="modal-service">${a.service}</span> com <strong style="color:var(--text)">${a.barber}</strong> em ${a.date} às ${a.time}?<br/>Esta ação não pode ser desfeita.</div>
      <div class="modal-actions">
        <button class="btn-danger" onclick="cancelAppt(${idx})"><i class="ti ti-trash"></i> SIM, CANCELAR</button>
        <button class="btn-outline" onclick="closeModal()">MANTER AGENDAMENTO</button>
      </div>
    </div>`;
  document.body.appendChild(modal);
}
function cancelAppt(idx){
  appointments.splice(idx,1);closeModal();updateAppts();updateStats();
}
function closeModal(){
  const m=document.getElementById('cancel-modal');if(m)m.remove();
}

// ══ EDIT ══
function editAppt(idx){
  const a=appointments[idx];
  state.service={name:a.service,price:a.price};
  state.editIdx=idx;
  const catKey=Object.keys(SERVICES).find(k=>SERVICES[k].some(s=>s.name===a.service))||'corte';
  showServices(catKey);
  document.getElementById('srv-title-desk').textContent='Alterar: '+CAT_NAMES[catKey];
  // override onclick to pass editIdx
  document.querySelectorAll('#srv-list-desk .service-item').forEach((el,i)=>{
    const srv=SERVICES[catKey][i];
    el.onclick=()=>selectServiceEdit(srv,idx);
  });
  gotoApp('a-services');
}
function selectServiceEdit(srv,idx){
  state.service=srv;state.editIdx=idx;
  document.getElementById('cal-srv-label-desk').textContent=srv.name+' (alteração)';
  const now=new Date();
  calState.year=now.getFullYear();calState.month=now.getMonth();calState.viewMonth=now.getMonth();
  calState.selectedDay=null;calState.selectedBarber=null;calState.selectedTime=null;
  buildCalendar();
  gotoApp('a-calendar');
}
</script>
</body>
</html>
