<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Esqueceu a Senha — Barbearia JLMGG</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/tabler-icons.min.css"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#080808;
  --surface:#0f0f0f;
  --surface2:#141414;
  --surface3:#1a1a1a;
  --blue:#4fc3f7;
  --blue2:#0288d1;
  --blue3:#01579b;
  --blue-dim:rgba(79,195,247,0.08);
  --blue-dim2:rgba(79,195,247,0.14);
  --blue-border:rgba(79,195,247,0.22);
  --blue-border2:rgba(79,195,247,0.40);
  --text:#f0f0f0;
  --text2:#888;
  --text3:#3a3a3a;
  --r:14px;
  --r-sm:9px;
}

html,body{
  height:100%;
  background:var(--bg);
  font-family:'DM Sans',sans-serif;
  color:var(--text);
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:auto;
  padding:24px;
}

/* ══ SCROLLBAR ══ */
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:4px;}

/* ══ AUTH CONTAINER ══ */
.auth-container{
  width:100%;max-width:420px;
  background:var(--surface);
  border:0.5px solid #1e1e1e;
  border-radius:20px;
  padding:40px 36px;
  box-shadow:0 0 80px rgba(0,0,0,0.6);
  position:relative;
  overflow:hidden;
}
.auth-container::before{
  content:'';position:absolute;top:-80px;right:-80px;
  width:240px;height:240px;border-radius:50%;
  background:radial-gradient(circle,rgba(2,136,209,0.10) 0%,transparent 70%);
  pointer-events:none;
}

.back-row{
  display:flex;align-items:center;gap:10px;
  margin-bottom:28px;cursor:pointer;
  color:var(--text2);transition:color .2s;
  font-size:13px;font-weight:500;
}
.back-row:hover{color:var(--blue);}
.back-row i{font-size:18px;}

.auth-hero{text-align:center;margin-bottom:24px;}
.auth-logo{
  width:64px;height:64px;border-radius:50%;
  background:linear-gradient(135deg,#0277bd,#01579b);
  margin:0 auto 16px;
  display:flex;align-items:center;justify-content:center;
  border:2px solid var(--blue-border);
  box-shadow:0 0 32px rgba(2,136,209,0.25);
}
.auth-logo span{font-family:'Bebas Neue',sans-serif;font-size:22px;color:#fff;letter-spacing:2px;}
.auth-title{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:3px;color:var(--text);}
.auth-sub{font-size:12px;color:var(--text2);margin-top:5px;}

/* ══ STEPS ══ */
.step-pane{display:none;flex-direction:column;gap:16px;}
.step-pane.active{display:flex;}

/* ══ FORM ══ */
.form-group{margin-bottom:0;}
.form-group label{
  font-size:10px;color:var(--text2);display:block;
  margin-bottom:7px;letter-spacing:1px;text-transform:uppercase;
}
.form-group input{
  width:100%;background:var(--bg);
  border:0.5px solid #252525;
  border-radius:var(--r-sm);padding:12px 14px;
  color:var(--text);font-size:14px;outline:none;
  font-family:'DM Sans',sans-serif;
  transition:border-color .2s,box-shadow .2s;
}
.form-group input:focus{
  border-color:var(--blue-border2);
  box-shadow:0 0 0 3px rgba(79,195,247,0.06);
}
.form-group input::placeholder{color:var(--text3);}

.input-icon-wrap{position:relative;}
.input-icon-wrap input{padding-left:40px;}
.input-icon-wrap .inp-icon{
  position:absolute;left:13px;top:50%;transform:translateY(-50%);
  color:var(--text3);font-size:17px;pointer-events:none;
}
.input-icon-wrap .inp-toggle{
  position:absolute;right:13px;top:50%;transform:translateY(-50%);
  color:var(--text3);font-size:16px;cursor:pointer;
}
.input-icon-wrap .inp-toggle:hover{color:var(--blue);}
.input-icon-wrap input{padding-right:40px;}

/* ══ BUTTONS ══ */
.btn-confirm{
  width:100%;background:var(--blue2);color:#fff;
  border:none;border-radius:var(--r-sm);padding:14px;
  font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:2px;
  cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;
  transition:background .2s,transform .15s,box-shadow .2s;
}
.btn-confirm:hover{background:#0277bd;box-shadow:0 4px 20px rgba(2,136,209,0.3);}
.btn-confirm:active{transform:scale(0.99);}

/* ══ MISC ══ */
.auth-info-box{
  background:var(--blue-dim);border:0.5px solid var(--blue-border);
  border-radius:var(--r-sm);padding:12px 14px;
  font-size:12px;color:var(--blue);
  display:flex;align-items:flex-start;gap:8px;
}
.auth-info-box i{font-size:16px;flex-shrink:0;margin-top:1px;}

.auth-link-row{text-align:center;font-size:12px;color:var(--text2);}
.auth-link{color:var(--blue);cursor:pointer;font-weight:500;}
.auth-link:hover{text-decoration:underline;}

/* ══ PASSWORD STRENGTH ══ */
.password-strength{margin-top:8px;}
.strength-bar{height:3px;border-radius:2px;background:#1e1e1e;overflow:hidden;}
.strength-fill{height:100%;border-radius:2px;transition:width .3s,background .3s;}
.strength-label{font-size:10px;color:var(--text3);margin-top:4px;}

/* ══ SUCESSO ══ */
.success-small{text-align:center;padding:16px 0 8px;}
.success-small .s-icon{
  width:64px;height:64px;border-radius:50%;
  background:var(--blue-dim);border:1px solid var(--blue-border);
  display:flex;align-items:center;justify-content:center;
  color:var(--blue);font-size:30px;margin:0 auto 16px;
}
.success-small .s-title{
  font-family:'Bebas Neue',sans-serif;font-size:22px;
  letter-spacing:2px;color:var(--text);margin-bottom:8px;
}
.success-small .s-sub{font-size:13px;color:var(--text2);line-height:1.6;}

/* ══ CÓDIGO ══ */
.code-input{
  letter-spacing:8px;text-align:center;
  font-size:22px;font-family:'Bebas Neue',sans-serif;
}
</style>
</head>
<body>

<div class="auth-container">

  <!-- Voltar ao login -->
  <a href="/Account/Login" class="back-row" style="text-decoration:none;">
    <i class="ti ti-arrow-left"></i>
    <span>Voltar ao login</span>
  </a>

  <div class="auth-hero">
    <div class="auth-logo"><span>JL</span></div>
    <div class="auth-title">Esqueci a Senha</div>
    <div class="auth-sub">Redefinição de acesso</div>
  </div>

  <!-- ── ETAPA 0 — Informar e-mail ── -->
  <div class="step-pane active" id="forgot-step-0">
    <div class="auth-info-box">
      <i class="ti ti-info-circle"></i>
      <span>Informe o e-mail cadastrado. Enviaremos um código para redefinir sua senha.</span>
    </div>
    <div class="form-group">
      <label>E-mail Cadastrado</label>
      <div class="input-icon-wrap">
        <i class="ti ti-mail inp-icon"></i>
        <input type="email" id="forgot-email" placeholder="seu@email.com"/>
      </div>
    </div>
    <button class="btn-confirm" onclick="sendCode()">
      <i class="ti ti-send"></i> ENVIAR CÓDIGO
    </button>
  </div>

  <!-- ── ETAPA 1 — Código de verificação ── -->
  <div class="step-pane" id="forgot-step-1">
    <div class="auth-info-box">
      <i class="ti ti-mail-opened"></i>
      <span>Código enviado! Verifique sua caixa de entrada e insira o código de 6 dígitos.</span>
    </div>
    <div class="form-group">
      <label>Código de Verificação</label>
      <div class="input-icon-wrap">
        <i class="ti ti-keyframe inp-icon"></i>
        <input class="code-input" type="text" id="forgot-code"
               placeholder="000000" maxlength="6"/>
      </div>
    </div>
    <button class="btn-confirm" onclick="verifyCode()">
      <i class="ti ti-check"></i> VERIFICAR
    </button>
    <div class="auth-link-row">
      Não recebeu?
      <span class="auth-link" onclick="sendCode()">Reenviar código</span>
    </div>
  </div>

  <!-- ── ETAPA 2 — Nova senha ── -->
  <div class="step-pane" id="forgot-step-2">
    <div class="form-group">
      <label>Nova Senha</label>
      <div class="input-icon-wrap">
        <i class="ti ti-lock inp-icon"></i>
        <input type="password" id="new-pass" placeholder="Mínimo 8 caracteres"
               oninput="checkStrength(this.value)"/>
        <i class="ti ti-eye inp-toggle" onclick="togglePass('new-pass',this)"></i>
      </div>
      <div class="password-strength">
        <div class="strength-bar">
          <div class="strength-fill" id="strength-fill2" style="width:0%"></div>
        </div>
        <div class="strength-label" id="strength-label2">Digite uma senha</div>
      </div>
    </div>
    <div class="form-group">
      <label>Confirmar Nova Senha</label>
      <div class="input-icon-wrap">
        <i class="ti ti-lock-check inp-icon"></i>
        <input type="password" id="new-pass2" placeholder="Repita a senha"/>
        <i class="ti ti-eye inp-toggle" onclick="togglePass('new-pass2',this)"></i>
      </div>
    </div>
    <button class="btn-confirm" onclick="saveNewPass()">
      <i class="ti ti-device-floppy"></i> SALVAR SENHA
    </button>
  </div>

  <!-- ── ETAPA 3 — Sucesso ── -->
  <div class="step-pane" id="forgot-step-3">
    <div class="success-small">
      <div class="s-icon"><i class="ti ti-lock-open"></i></div>
      <div class="s-title">Senha Redefinida!</div>
      <div class="s-sub">
        Sua senha foi alterada com sucesso.<br/>
        Agora você pode fazer login.
      </div>
    </div>
    <button class="btn-confirm" onclick="window.location.href='/Account/Login'">
      <i class="ti ti-login"></i> IR PARA O LOGIN
    </button>
  </div>

</div><!-- /auth-container -->

<script>
function forgotShowStep(n) {
  for (let i = 0; i < 4; i++) {
    const p = document.getElementById('forgot-step-' + i);
    if (p) p.classList.toggle('active', i === n);
  }
}

function sendCode() {
  const email = document.getElementById('forgot-email').value.trim();
  if (!email) { alert('Informe seu e-mail cadastrado.'); return; }
  // ── Adapte aqui para chamar sua API/Controller ──
  forgotShowStep(1);
}

function verifyCode() {
  const code = document.getElementById('forgot-code').value.trim();
  if (code.length < 6) { alert('Digite o código de 6 dígitos.'); return; }
  // ── Adapte aqui para validar o código no servidor ──
  forgotShowStep(2);
}

function saveNewPass() {
  const p1 = document.getElementById('new-pass').value;
  const p2 = document.getElementById('new-pass2').value;
  if (p1.length < 8)  { alert('A senha deve ter pelo menos 8 caracteres.'); return; }
  if (p1 !== p2)      { alert('As senhas não coincidem.'); return; }
  // ── Adapte aqui para salvar a nova senha no servidor ──
  forgotShowStep(3);
}

function togglePass(id, icon) {
  const inp = document.getElementById(id);
  if (inp.type === 'password') {
    inp.type = 'text';
    icon.classList.replace('ti-eye', 'ti-eye-off');
  } else {
    inp.type = 'password';
    icon.classList.replace('ti-eye-off', 'ti-eye');
  }
}

const STRENGTH_LEVELS = [
  { w:'20%', bg:'#e53935', label:'Muito fraca'  },
  { w:'40%', bg:'#ef6c00', label:'Fraca'         },
  { w:'60%', bg:'#fbc02d', label:'Razoável'      },
  { w:'80%', bg:'#7cb342', label:'Boa'           },
  { w:'100%',bg:'#2e7d32', label:'Forte'         },
];
function _strengthScore(v) {
  let s = 0;
  if (v.length >= 8)           s++;
  if (/[A-Z]/.test(v))         s++;
  if (/[0-9]/.test(v))         s++;
  if (/[^A-Za-z0-9]/.test(v))  s++;
  if (v.length >= 12)           s++;
  return Math.min(s, 4);
}
function checkStrength(v) {
  const idx = v.length ? _strengthScore(v) : 0;
  const l   = v.length ? STRENGTH_LEVELS[idx] : null;
  document.getElementById('strength-fill2').style.width      = l ? l.w  : '0%';
  document.getElementById('strength-fill2').style.background = l ? l.bg : '';
  document.getElementById('strength-label2').textContent      = l ? l.label : 'Digite uma senha';
}
</script>
</body>
</html>
