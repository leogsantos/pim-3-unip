@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Criar Conta — Barbearia JLMGG</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/tabler-icons.min.css"/>

@* Linkando arquivo css da pasta wwwrot  *@
<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

</head>
<body>

<div class="auth-container">

  <div class="auth-hero">
    <div class="auth-logo"><span>JL</span></div>
    <div class="auth-title">Criar Conta</div>
    <div class="auth-sub">Preencha seus dados abaixo</div>
  </div>

  <!-- INDICADOR DE ETAPAS -->
  <div class="steps-indicator" id="reg-steps">
    <div class="step-dot active" id="rdot-0"></div>
    <div class="step-dot" id="rdot-1"></div>
    <div class="step-dot" id="rdot-2"></div>
  </div>

  <!-- ── ETAPA 0 — Dados pessoais ── -->
  <div class="step-pane active" id="reg-step-0">
    <div class="form-row">
      <div class="form-group">
        <label>Nome Completo</label>
        <div class="input-icon-wrap">
          <i class="ti ti-user inp-icon"></i>
          <input type="text" id="reg-name" placeholder="Ex: João da Silva"/>
        </div>
      </div>
      <div class="form-group">
        <label>Telefone / WhatsApp</label>
        <div class="input-icon-wrap">
          <i class="ti ti-phone inp-icon"></i>
          <input type="tel" id="reg-phone" placeholder="(13) 99999-9999"/>
        </div>
      </div>
    </div>
    <button class="btn-confirm" onclick="regNext(0)">
      PRÓXIMO <i class="ti ti-arrow-right"></i>
    </button>
    <div class="auth-link-row">
      Já tem conta? <span class="auth-link" onclick="window.location.href='/Account/Login'">Entrar</span>
    </div>
  </div>

  <!-- ── ETAPA 1 — E-mail e senha ── -->
  <div class="step-pane" id="reg-step-1">
    <div class="form-group">
      <label>E-mail</label>
      <div class="input-icon-wrap">
        <i class="ti ti-mail inp-icon"></i>
        <input type="email" id="reg-email" placeholder="seu@email.com"/>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Senha</label>
        <div class="input-icon-wrap">
          <i class="ti ti-lock inp-icon"></i>
          <input type="password" id="reg-pass" placeholder="Mínimo 8 caracteres"
                 oninput="checkStrength(this.value)"/>
          <i class="ti ti-eye inp-toggle" onclick="togglePass('reg-pass',this)"></i>
        </div>
        <div class="password-strength">
          <div class="strength-bar">
            <div class="strength-fill" id="strength-fill" style="width:0%"></div>
          </div>
          <div class="strength-label" id="strength-label">Digite uma senha</div>
        </div>
      </div>
      <div class="form-group">
        <label>Confirmar Senha</label>
        <div class="input-icon-wrap">
          <i class="ti ti-lock-check inp-icon"></i>
          <input type="password" id="reg-pass2" placeholder="Repita a senha"/>
          <i class="ti ti-eye inp-toggle" onclick="togglePass('reg-pass2',this)"></i>
        </div>
      </div>
    </div>
    <div style="display:flex;gap:10px;">
      <button class="btn-outline" style="max-width:120px" onclick="regBack(1)">
        <i class="ti ti-arrow-left"></i> VOLTAR
      </button>
      <button class="btn-confirm" onclick="regNext(1)">
        PRÓXIMO <i class="ti ti-arrow-right"></i>
      </button>
    </div>
  </div>

  <!-- ── ETAPA 2 — Revisão e confirmação ── -->
  <div class="step-pane" id="reg-step-2">
    <div class="auth-info-box">
      <i class="ti ti-shield-check"></i>
      <span>Seus dados estão seguros e usados apenas para facilitar seus agendamentos.</span>
    </div>
    <div class="confirm-card">
      <div class="card-label">Resumo do cadastro</div>
      <div class="confirm-row">
        <span class="lbl"><i class="ti ti-user"></i>Nome</span>
        <span class="val" id="sum-name">—</span>
      </div>
      <div class="confirm-row">
        <span class="lbl"><i class="ti ti-phone"></i>Telefone</span>
        <span class="val" id="sum-phone">—</span>
      </div>
      <div class="confirm-row" style="border-bottom:none">
        <span class="lbl"><i class="ti ti-mail"></i>E-mail</span>
        <span class="val" id="sum-email" style="font-size:12px">—</span>
      </div>
    </div>
    <div style="display:flex;gap:10px;">
      <button class="btn-outline" style="max-width:120px" onclick="regBack(2)">
        <i class="ti ti-arrow-left"></i> VOLTAR
      </button>
      <button class="btn-confirm" onclick="finishRegister()">
        <i class="ti ti-check"></i> CADASTRAR
      </button>
    </div>
  </div>

</div><!-- /auth-container -->

<script src="~/js/registration.js" asp-append-version="true"></script>
</body>
</html>
